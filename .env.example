# Gateway port (host side)
GATEWAY_PORT=9003

# Auth tokens
MOCK_ADMIN_TOKEN=mock-admin-secret
MOCK_TESTER_TOKEN=mock-tester-secret
MOCK_VIEWER_TOKEN=mock-dev-secret

# Upstream URLs — set based on environment
# local:  leave unset (defaults to localhost in config.yaml)
# uat:    set to UAT backend
# prod:   set to prod backend
CARDHUB_URL=https://cardhub-uat.popclub.co.in
SERVICE_B_URL=https://service-b-uat.popclub.co.in
